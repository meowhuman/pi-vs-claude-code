# =============================================================================
# Football Betting Board — API Keys
# =============================================================================

# -----------------------------------------------------------------------------
# 1. CLOUDBET (你的投注平台)
# -----------------------------------------------------------------------------
# Get your API token from: https://www.cloudbet.com/api
CLOUDBET_API_TOKEN=your_cloudbet_api_token_here

# Optional settings
CLOUDBET_ENV=live              # 'sandbox' for testing, 'live' for real money
CLOUDBET_CURRENCY=USDT         # USDT, BTC, ETH, USDC

# -----------------------------------------------------------------------------
# 2. The Odds API (赔率比较)
# -----------------------------------------------------------------------------
# Get free key from: https://the-odds-api.com/
# Free tier: 500 requests/month
ODDS_API_KEY=your_odds_api_key_here

# -----------------------------------------------------------------------------
# 3. football-data.org (赛程、积分榜、比赛结果)
# -----------------------------------------------------------------------------
# Get free key from: https://www.football-data.org/
# Free tier: 500 requests/day
# 注意：这是 HTTP API Key，不是 Kaggle！
FOOTBALL_DATA_KEY=your_football_data_key_here

# -----------------------------------------------------------------------------
# 4. SportAPI7 (球员赛季统计 — 已用完配额，下月恢复)
# -----------------------------------------------------------------------------
# Get from: https://rapidapi.com/tipsters/api/sportapi7
# Free tier: 500 requests/month (rate limited ~5-10 req/min)
SPORTAPI7_KEY=your_sportapi7_key_here

# =============================================================================
# KAGGLE (不是放在这里！)
# =============================================================================
# Kaggle 使用单独的配置文件：
#   ~/.kaggle/kaggle.json
# 
# 格式：
#   {"username":"your_username","key":"your_kaggle_key"}
#
# 用途：下载 FBref 球员统计数据集
# 数据集：hubertsidorowicz/football-players-stats-2025-2026
# =============================================================================
KAGGLE_API_KEY=