# Polymarket Trader 環境變數配置
# 複製此文件為 .env 並填入你的實際值

# ========================================
# 錢包配置
# ========================================

# 你的 Polygon 私鑰 (64 字符 hex string, 不含 0x prefix)
# ⚠️ 重要: 絕對不要將 .env 文件 commit 到 git!
POLYGON_PRIVATE_KEY=


# 你的錢包地址
WALLET_ADDRESS=0xF57465a0200Db390e42Ce3AFd40885480B0ccEB2

# ========================================
# 網絡配置
# ========================================

# Polygon RPC URL
POLYGON_RPC_URL=https://polygon-rpc.com

# ========================================
# 交易配置
# ========================================

# 自動執行的最大金額 (USDC)
MAX_AUTO_AMOUNT=1.0
