    <key>Alpha Component</key><real>1</real>
    <key>Blue Component</key><real>0.78431</real>
    <key>Color Space</key><string>sRGB</string>
    <key>Green Component</key><real>0.72157</real>
    <key>Red Component</key><real>0.65882</real>
