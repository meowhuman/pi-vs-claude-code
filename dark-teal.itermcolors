<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  dark-teal — iTerm2 color theme
  Inspired by the Pi Coding Agent multi-agent terminal aesthetic.

  Palette:
    Background  #0A0E14   near-black navy
    Foreground  #B8CDD8   light gray-blue
    Accent      #56D4C8   teal  (Orch / cursor / active)
    Lead nodes  #D89040   amber-orange
    Sub-agents  #4DBBF0   soft blue
    Diamonds    #D876A8   pink-magenta

  To install: double-click this file, or
    Preferences > Profiles > Colors > Color Presets… > Import
-->
<dict>

  <!-- ── Ansi 0-7 ────────────────────────────────────────────────── -->
  <!-- 0 Black -->
  <key>Ansi 0 Color</key>
  <dict>
    <key>Alpha Component</key><real>1</real>
    <key>Blue Component</key><real>0.14902</real>
    <key>Color Space</key><string>sRGB</string>
    <key>Green Component</key><real>0.11765</real>
    <key>Red Component</key><real>0.10196</real>
  </dict>
  <!-- 1 Red -->
  <key>Ansi 1 Color</key>
  <dict>
    <key>Alpha Component</key><real>1</real>
    <key>Blue Component</key><real>0.41569</real>
    <key>Color Space</key><string>sRGB</string>
    <key>Green Component</key><real>0.43922</real>
    <key>Red Component</key><real>0.87843</real>
  </dict>
  <!-- 2 Green -->
  <key>Ansi 2 Color</key>
  <dict>
    <key>Alpha Component</key><real>1</real>
    <key>Blue Component</key><real>0.58824</real>
    <key>Color Space</key><string>sRGB</string>
    <key>Green Component</key><real>0.78431</real>
    <key>Red Component</key><real>0.31373</real>
  </dict>
  <!-- 3 Yellow / Amber-orange — Lead nodes -->
  <key>Ansi 3 Color</key>
  <dict>
    <key>Alpha Component</key><real>1</real>
    <key>Blue Component</key><real>0.25098</real>
    <key>Color Space</key><string>sRGB</string>
    <key>Green Component</key><real>0.56471</real>
    <key>Red Component</key><real>0.84706</real>
  </dict>
  <!-- 4 Blue — Sub-agent nodes -->
  <key>Ansi 4 Color</key>
  <dict>
    <key>Alpha Component</key><real>1</real>
    <key>Blue Component</key><real>0.94118</real>
    <key>Color Space</key><string>sRGB</string>
    <key>Green Component</key><real>0.73333</real>
    <key>Red Component</key><real>0.30196</real>
  </dict>
  <!-- 5 Magenta / Pink — Diamond symbols -->
  <key>Ansi 5 Color</key>
  <dict>
    <key>Alpha Component</key><real>1</real>
    <key>Blue Component</key><real>0.65882</real>
    <key>Color Space</key><string>sRGB</string>
    <key>Green Component</key><real>0.46275</real>
    <key>Red Component</key><real>0.84706</real>
  </dict>
  <!-- 6 Cyan / Teal — Main accent (Orch, highlights) -->
  <key>Ansi 6 Color</key>
  <dict>
    <key>Alpha Component</key><real>1</real>
    <key>Blue Component</key><real>0.78431</real>
    <key>Color Space</key><string>sRGB</string>
    <key>Green Component</key><real>0.83137</real>
    <key>Red Component</key><real>0.33725</real>
  </dict>
  <!-- 7 White -->
